\cb3 "\uc0\u928 \u945 \u957 \u945 \u947 \u943 \u945  \u932 \u961 \u953 \u940 \u962  \u966 \u974 \u964 \u953 \u963 \u959 \u957  \u7969 \u956 \u8118 \u962  \u964 \u943  \u948 \u949 \u8150  \u7969 \u956 \u8118 \u962  \u960 \u959 \u953 \u949 \u8150 \u957  \u954 \u945 \u943  \u955 \u941 \u947 \u949 \u953 \u957 !"\cb1 \
\
\cb3 \'a0\cb1 \
\cb3 "\uc0\u916 \u972 \u958 \u945  \u963 \u959 \u953  \u8001  \u920 \u949 \u972 \u962  \u7969 \u956 \u8182 \u957 , \u948 \u972 \u958 \u945  \u963 \u959 \u953 ."\cb1 \
\cb3 \'a0\cb1 \
\cb3 "\uc0\u8009  \u920 \u949 \u972 \u962 , \u7985 \u955 \u940 \u963 \u952 \u951 \u964 \u943  \u956 \u959 \u953 , \u964 \u8183  \u7937 \u956 \u945 \u961 \u964 \u969 \u955 \u8183 , \u954 \u945 \u943  \u7952 \u955 \u941 \u951 \u963 \u972 \u957  \u956 \u949 ."\cb1 \
\cb3 \'a0\cb1 \
\cb3 "\uc0\u7960 \u955 \u941 \u951 \u963 \u972 \u957  \u956 \u949 , \u8001  \u920 \u949 \u972 \u962 , \u7952 \u955 \u941 \u951 \u963 \u972 \u957  \u956 \u949  \u954 \u945 \u964 \u940  \u964 \u972  \u956 \u941 \u947 \u945  \u7956 \u955 \u949 \u972 \u962  \u931 \u959 \u965 ."\
\
\uc0\u927  \u920 \u949 \u972 \u962  \u945 \u957 \u940 \u960 \u945 \u965 \u963 \u959 \u957  \u964 \u945 \u962  \u968 \u965 \u967 \u940 \u962  \u964 \u969 \u957  \u954 \u949 \u954 \u959 \u953 \u956 \u951 \u956 \u949 \u957 \u969 \u957  \u948 \u959 \u965 \u955 \u969 \u957  \u963 \u959 \u965 .\cb1 \
\
\cb3 \uc0\u8025 \u960 \u949 \u961 \u941 \u957 \u948 \u959 \u958 \u949 , \u7936 \u949 \u953 \u960 \u940 \u961 \u952 \u949 \u957 \u949 , \u949 \u8016 \u955 \u959 \u947 \u951 \u956 \u941 \u957 \u951  \u920 \u949 \u959 \u964 \u972 \u954 \u949 , \u960 \u961 \u959 \u963 \u940 \u947 \u945 \u947 \u949  \u964 \u942 \u957  \u7969 \u956 \u949 \u964 \u941 \u961 \u945 \u957  \u960 \u961 \u959 \u963 \u949 \u965 \u967 \u942 \u957 , \u964 \u8183  \u933 \u7985 \u8183  \u963 \u959 \u965  \u954 \u945 \u943  \u920 \u949 \u8183  \u7969 \u956 \u8182 \u957 , \u954 \u945 \u943  \u945 \u7988 \u964 \u951 \u963 \u945 \u953 , \u7989 \u957 \u945  \u963 \u974 \u963 \u8131  \u948 \u953 \u940  \u963 \u959 \u8166  \u964 \u940 \u962  \u968 \u965 \u967 \u940 \u962  \u7969 \u956 \u8182 \u957 \cb1 \
\
