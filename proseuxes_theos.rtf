\uc0\u916 \u972 \u958 \u945  \u963 \u959 \u953 , \u935 \u961 \u953 \u963 \u964 \u8050  \u8001  \u920 \u949 \u972 \u962 , \u7969  \u7952 \u955 \u960 \u8054 \u962  \u7969 \u956 \u8182 \u957 , \u948 \u972 \u958 \u945  \u963 \u959 \u953 .\
\pard\pardeftab720\sl320\partightenfactor0
\cf8 \uc0\u914 \u945 \u963 \u953 \u955 \u949 \u8166  \u959 \u8016 \u961 \u940 \u957 \u953 \u949 , \u928 \u945 \u961 \u940 \u954 \u955 \u951 \u964 \u949 , \u964 \u8056  \u928 \u957 \u949 \u8166 \u956 \u945  \u964 \u8134 \u962  \u7936 \u955 \u951 \u952 \u949 \u943 \u945 \u962 , \u8001  \u960 \u945 \u957 \u964 \u945 \u967 \u959 \u8166  \u960 \u945 \u961 \u8060 \u957  \u954 \u945 \u8054  \u964 \u8048  \u960 \u940 \u957 \u964 \u945  \u960 \u955 \u951 \u961 \u8182 \u957 , \u8001  \u952 \u951 \u963 \u945 \u965 \u961 \u8056 \u962  \u964 \u8182 \u957  \u7936 \u947 \u945 \u952 \u8182 \u957  \u954 \u945 \u8054  \u950 \u969 \u8134 \u962  \u967 \u959 \u961 \u951 \u947 \u972 \u962 , \u7952 \u955 \u952 \u8050  \u954 \u945 \u8054  \u963 \u954 \u942 \u957 \u969 \u963 \u959 \u957  \u7952 \u957  \u7969 \u956 \u8150 \u957 , \u954 \u945 \u8054  \u954 \u945 \u952 \u940 \u961 \u953 \u963 \u959 \u957  \u7969 \u956 \u8118 \u962  \u7936 \u960 \u8056  \u960 \u940 \u963 \u951 \u962  \u954 \u951 \u955 \u8150 \u948 \u959 \u962 , \u954 \u945 \u8054  \u963 \u8182 \u963 \u959 \u957 , \u7944 \u947 \u945 \u952 \u941 , \u964 \u8048 \u962  \u968 \u965 \u967 \u8048 \u962  \u7969 \u956 \u8182 \u957 . \u7944 \u956 \u942 \u957 .\
\
\uc0\u7949 \u947 \u953 \u959 \u962  \u8001  \u920 \u949 \u972 \u962 , \u7941 \u947 \u953 \u959 \u962  \u7984 \u963 \u967 \u965 \u961 \u972 \u962 , \u7941 \u947 \u953 \u959 \u962  \u7936 \u952 \u940 \u957 \u945 \u964 \u959 \u962 , \u7952 \u955 \u941 \u951 \u963 \u959 \u957  \u7969 \u956 \u8118 \u962 \'a0\cf10 (\uc0\u7952 \u954  \u947 \u8189 ).\
\
\cf8 \uc0\u916 \u972 \u958 \u945  \u928 \u945 \u964 \u961 \u8054  \u954 \u945 \u8054  \u933 \u7985 \u8183  \u954 \u945 \u8054  \u7937 \u947 \u943 \u8179  \u928 \u957 \u949 \u973 \u956 \u945 \u964 \u953 . \u922 \u945 \u8054  \u957 \u8166 \u957  \u954 \u945 \u8054  \u7936 \u949 \u8054  \u954 \u945 \u8054  \u949 \u7984 \u962  \u964 \u959 \u8058 \u962  \u945 \u7984 \u8182 \u957 \u945 \u962  \u964 \u8182 \u957  \u945 \u7984 \u974 \u957 \u969 \u957 . \u7944 \u956 \u942 \u957 .\
\
\uc0\u922 \u973 \u961 \u953 \u949 , \u7952 \u955 \u941 \u951 \u963 \u959 \u957 \u903  \u922 \u973 \u961 \u953 \u949 , \u7952 \u955 \u941 \u951 \u963 \u959 \u957 \u903  \u922 \u973 \u961 \u953 \u949 , \u7952 \u955 \u941 \u951 \u963 \u959 \u957 .\
\
\uc0\u928 \u940 \u964 \u949 \u961  \u7969 \u956 \u8182 \u957  \u8001  \u7952 \u957  \u964 \u959 \u8150 \u962  \u959 \u8016 \u961 \u945 \u957 \u959 \u8150 \u962 , \u7937 \u947 \u953 \u945 \u963 \u952 \u942 \u964 \u969  \u964 \u8056  \u8004 \u957 \u959 \u956 \u940  \u963 \u959 \u965 . \u7960 \u955 \u952 \u941 \u964 \u969  \u7969  \u946 \u945 \u963 \u953 \u955 \u949 \u943 \u945  \u963 \u959 \u965 . \u915 \u949 \u957 \u951 \u952 \u942 \u964 \u969  \u964 \u8056  \u952 \u941 \u955 \u951 \u956 \u940  \u963 \u959 \u965 , \u8033 \u962  \u7952 \u957  \u959 \u8016 \u961 \u945 \u957 \u8183 , \u954 \u945 \u8054  \u7952 \u960 \u8054  \u964 \u8134 \u962  \u947 \u8134 \u962 . \u932 \u8056 \u957  \u7940 \u961 \u964 \u959 \u957  \u7969 \u956 \u8182 \u957  \u964 \u8056 \u957  \u7952 \u960 \u953 \u959 \u973 \u963 \u953 \u959 \u957  \u948 \u8056 \u962  \u7969 \u956 \u8150 \u957  \u963 \u942 \u956 \u949 \u961 \u959 \u957 . \u922 \u945 \u8054  \u7940 \u966 \u949 \u962  \u7969 \u956 \u8150 \u957  \u964 \u8048  \u8000 \u966 \u949 \u953 \u955 \u942 \u956 \u945 \u964 \u945  \u7969 \u956 \u8182 \u957 , \u8033 \u962  \u954 \u945 \u8054  \u7969 \u956 \u949 \u8150 \u962  \u7936 \u966 \u943 \u949 \u956 \u949 \u957  \u964 \u959 \u8150 \u962  \u8000 \u966 \u949 \u953 \u955 \u941 \u964 \u945 \u953 \u962  \u7969 \u956 \u8182 \u957 . \u922 \u945 \u8054  \u956 \u8052  \u949 \u7984 \u963 \u949 \u957 \u941 \u947 \u954 \u8131 \u962  \u7969 \u956 \u8118 \u962  \u949 \u7984 \u962  \u960 \u949 \u953 \u961 \u945 \u963 \u956 \u972 \u957 , \u7936 \u955 \u955 \u8048  \u8165 \u8166 \u963 \u945 \u953  \u7969 \u956 \u8118 \u962  \u7936 \u960 \u8056  \u964 \u959 \u8166  \u960 \u959 \u957 \u951 \u961 \u959 \u8166 . \u7944 \u956 \u942 \u957 .\
\
\uc0\u916 \u972 \u958 \u945  \u7952 \u957  \u8017 \u968 \u943 \u963 \u964 \u959 \u953 \u962  \u920 \u949 \u8183 , \u954 \u945 \u8054  \u7952 \u960 \u8054  \u947 \u8134 \u962  \u949 \u7984 \u961 \u942 \u957 \u951 , \u7952 \u957  \u7936 \u957 \u952 \u961 \u974 \u960 \u959 \u953 \u962  \u949 \u8016 \u948 \u959 \u954 \u943 \u945 .\
\
\uc0\u922 \u973 \u961 \u953 \u949 , \u914 \u945 \u963 \u953 \u955 \u949 \u8166 , \u7952 \u960 \u959 \u965 \u961 \u940 \u957 \u953 \u949  \u920 \u949 \u941 , \u928 \u940 \u964 \u949 \u961  \u960 \u945 \u957 \u964 \u959 \u954 \u961 \u940 \u964 \u959 \u961 \u903  \u922 \u973 \u961 \u953 \u949  \u933 \u7985 \u8050  \u956 \u959 \u957 \u959 \u947 \u949 \u957 \u941 \u962 , \u7992 \u951 \u963 \u959 \u8166  \u935 \u961 \u953 \u963 \u964 \u941 , \u954 \u945 \u8054  \u7941 \u947 \u953 \u959 \u957  \u928 \u957 \u949 \u8166 \u956 \u945 .\
\
\uc0\u922 \u973 \u961 \u953 \u949  \u8001  \u920 \u949 \u972 \u962 , \u8001  \u7936 \u956 \u957 \u8056 \u962  \u964 \u959 \u8166  \u920 \u949 \u959 \u8166 , \u8001  \u933 \u7985 \u8056 \u962  \u964 \u959 \u8166  \u928 \u945 \u964 \u961 \u972 \u962 , \u8001  \u945 \u7988 \u961 \u969 \u957  \u964 \u8052 \u957  \u7937 \u956 \u945 \u961 \u964 \u943 \u945 \u957  \u964 \u959 \u8166  \u954 \u972 \u963 \u956 \u959 \u965 , \u7952 \u955 \u941 \u951 \u963 \u959 \u957  \u7969 \u956 \u8118 \u962 , \u8001  \u945 \u7988 \u961 \u969 \u957  \u964 \u8048 \u962  \u7937 \u956 \u945 \u961 \u964 \u943 \u945 \u962  \u964 \u959 \u8166  \u954 \u972 \u963 \u956 \u959 \u965 .\
\
\uc0\u8013 \u964 \u953  \u963 \u8058  \u949 \u7990  \u956 \u972 \u957 \u959 \u962  \u7949 \u947 \u953 \u959 \u962 , \u963 \u8058  \u949 \u7990  \u956 \u972 \u957 \u959 \u962  \u922 \u973 \u961 \u953 \u959 \u962 , \u7992 \u951 \u963 \u959 \u8166 \u962  \u935 \u961 \u953 \u963 \u964 \u972 \u962 , \u949 \u7984 \u962  \u948 \u972 \u958 \u945 \u957  \u920 \u949 \u959 \u8166  \u928 \u945 \u964 \u961 \u972 \u962 . \u7944 \u956 \u942 \u957 .\
\
\uc0\u922 \u945 \u964 \u945 \u958 \u943 \u969 \u963 \u959 \u957 , \u922 \u973 \u961 \u953 \u949 , \u7952 \u957  \u964 \u8135  \u7969 \u956 \u941 \u961 \u8115  \u964 \u945 \u973 \u964 \u8131 , \u7936 \u957 \u945 \u956 \u945 \u961 \u964 \u942 \u964 \u959 \u965 \u962  \u966 \u965 \u955 \u945 \u967 \u952 \u8134 \u957 \u945 \u953  \u7969 \u956 \u8118 \u962 .\
